# ═══════════════════════════════════════════════════════════════
# HUB RESA - Variables d'environnement Vercel
# Copier ce fichier en .env.local pour le développement
# Sur Vercel : ajouter ces variables dans Project Settings > Environment Variables
# ═══════════════════════════════════════════════════════════════

# ─── Base de données MySQL (Neon, PlanetScale, ou autre MySQL compatible) ───
DATABASE_URL=mysql://user:password@host/database?ssl={"rejectUnauthorized":true}

# ─── Sécurité JWT ────────────────────────────────────────────────────────────
# Clé secrète pour signer les tokens de session (min 32 caractères)
JWT_SECRET=votre_secret_tres_long_et_aleatoire_min_32_chars

# ─── Identifiant de l'application ────────────────────────────────────────────
VITE_APP_ID=hub_resa

# ─── Admins automatiques ──────────────────────────────────────────────────────
# Emails qui obtiennent automatiquement le rôle admin
ADMIN_EMAILS=admin@hubresa.com

# ─── OAuth Manus (OPTIONNEL - uniquement si utilisé sur plateforme Manus) ────
# OAUTH_SERVER_URL=https://oauth.manus.computer
# OWNER_OPEN_ID=

# ─── Stockage fichiers (AWS S3 ou compatible) ────────────────────────────────
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=

# ─── Intégration Hub2 (paiements) ────────────────────────────────────────────
# HUB2_API_KEY=
# HUB2_WEBHOOK_SECRET=

# ─── Environnement ────────────────────────────────────────────────────────────
NODE_ENV=production
